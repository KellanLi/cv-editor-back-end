generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // resumes   Resume[]  // 一个用户多个简历
}

