generator client {
  provider     = "prisma-client"
  output       = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  password         String
  name             String?
  gender           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  resumes          Resume[]
  contentTemplates ContentTemplate[]
  aiResumeDiagnosisTasks AiResumeDiagnosisTask[]
}

model Resume {
  id        Int            @id @default(autoincrement())
  userId    Int
  title     String
  /// 列表/卡片等场景展示用的封面图 URL
  listCoverImageUrl String?
  /// 该简历关联的职位描述（JD）全文；该简历下所有 AI 对话复用（优先于 `AiGlobalContext` key=job_description）
  jobDescriptionText String? @map("job_description_text") @db.LongText
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id])
  sections  Section[]
  /// 与简历 1:1 的个人信息
  profile   ResumeProfile?
  /// 同一份简历下可有多条独立 AI 对话（LangGraph thread 与表 `threadId` 对齐）
  aiConversations AiConversation[]
  /// 同一份简历下、跨所有对话复用的长上下文（如 JD）；按 `key` 区分
  aiGlobalContexts AiGlobalContext[]
  /// 简历 AI 诊断异步任务（可恢复查询）
  aiResumeDiagnosisTasks AiResumeDiagnosisTask[]
}

/// 简历个人信息（与 {@link Resume} 一对一）
model ResumeProfile {
  id             Int       @id @default(autoincrement())
  resumeId       Int       @unique
  /// 证件照 URL
  photoUrl       String?
  /// 简历展示用姓名（可与账户姓名不同）
  fullName       String?
  /// 出生日期（仅存日期，无时刻）
  birthDate      DateTime? @db.Date
  /// 性别（应用层约定值，如 "male" / "female" / "other"）
  gender         String?
  /// 目标岗位
  targetPosition String?
  /// 简历联系邮箱
  email          String?
  /// 联系电话
  phone          String?
  /// 可扩展字符串列表；应用层约定值为 string[]，如 ["wechat:wx_001", "city:上海"]
  profileExtra   Json?
  resume         Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Section {
  id                Int       @id @default(autoincrement())
  resumeId          Int
  contentTemplateId Int
  /// 同一简历内模块的展示顺序（升序）
  order             Int       @default(0)
  contents          Content[]
  resume            Resume    @relation(fields: [resumeId], references: [id])
}

model Content {
  id        Int     @id @default(autoincrement())
  sectionId Int
  order     Int
  section   Section @relation(fields: [sectionId], references: [id])
  infos     Info[]
}

model Info {
  id        Int     @id @default(autoincrement())
  contentId Int
  order     Int
  type      String
  values    Json
  content   Content @relation(fields: [contentId], references: [id])
}

model ContentTemplate {
  id            Int            @id @default(autoincrement())
  userId        Int
  name          String
  createdAt     DateTime       @default(now())
  infoTemplates InfoTemplate[]
  user          User           @relation(fields: [userId], references: [id])
}

model InfoTemplate {
  id                Int             @id @default(autoincrement())
  contentTemplateId Int
  type              String
  names             Json
  order             Int
  contentTemplate   ContentTemplate @relation(fields: [contentTemplateId], references: [id])
}

// --- AI（LangGraph：会话线程、消息、工具调用、简历级全局上下文；DB 为 MySQL）---

enum AiConversationPurpose {
  BASIC_QA
  DIALOGUE_EDIT
  RESUME_DIAGNOSIS
}

enum AiMessageRole {
  system
  user
  assistant
  tool
}

/// 异步历史压缩任务状态（长上下文：见 `docs/long-context.md`）
enum AiContextCompactionJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

/// 简历 AI 诊断任务状态（异步，可恢复查询）
enum AiResumeDiagnosisTaskStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

/// 简历 AI 诊断异步任务（绑定 userId，支持刷新后查询状态/结果）
model AiResumeDiagnosisTask {
  /// 对外暴露的任务 ID（UUID）
  id            String                      @id @db.VarChar(64)
  userId        Int                         @map("user_id")
  resumeId      Int                         @map("resume_id")
  status        AiResumeDiagnosisTaskStatus @default(QUEUED)
  /// 仅在 queued/running 时填 `${userId}:${resumeId}`，利用唯一约束保证同用户同简历最多一个活跃任务
  activeKey     String?                     @unique @map("active_key") @db.VarChar(64)
  /// 诊断请求快照（targetRole / enableWebSearch 等）
  requestPayload Json?                      @map("request_payload")
  /// 成功后的完整诊断报告（结构与同步接口一致）
  report        Json?
  errorMessage  String?                     @map("error_message") @db.Text
  /// 失败分类：business / system / cancelled
  failureCategory String?                   @map("failure_category") @db.VarChar(32)
  attempts      Int                         @default(0)
  startedAt     DateTime?                   @map("started_at")
  finishedAt    DateTime?                   @map("finished_at")
  expiresAt     DateTime                    @map("expires_at")
  createdAt     DateTime                    @default(now()) @map("created_at")
  updatedAt     DateTime                    @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([userId, resumeId, status])
  @@index([status, createdAt])
  @@index([expiresAt])
  @@map("ai_resume_diagnosis_task")
}

/// 一条「对话线程」：必须属于某份简历；同一份简历可有多条（多窗口/多主题）
model AiConversation {
  id        Int                   @id @default(autoincrement())
  resumeId  Int
  purpose   AiConversationPurpose @default(BASIC_QA)
  /// 与 LangGraph checkpointer 的 configurable.thread_id 对齐
  threadId  String                @unique @map("thread_id")
  title     String?
  status    String                @default("active")
  lastMsgAt DateTime?             @map("last_msg_at")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  resume   Resume      @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  /// 长上下文：已折叠历史的滚动摘要（每会话 0..1 行）
  contextSummary   AiConversationContextSummary?
  /// 长上下文：各次压缩产出的分块，便于按区间/审计/检索
  contextChunks    AiContextChunk[]
  /// 长上下文：异步压缩任务队列
  compactionJobs   AiContextCompactionJob[]

  @@index([resumeId, lastMsgAt(sort: Desc)])
  @@map("ai_conversation")
}

/// 长上下文：每会话「已折叠历史」的单一主读副本（`coversUpToSeq` 与 `AiMessage.seq` 对齐）
model AiConversationContextSummary {
  id             Int      @id @default(autoincrement())
  conversationId Int      @unique @map("conversation_id")
  rollingSummary String   @map("rolling_summary") @db.Text
  /// `1..coversUpToSeq` 已合并进 `rollingSummary`；0 表示尚无折叠
  coversUpToSeq  Int      @default(0) @map("covers_up_to_seq")
  version        Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_conversation_context_summary")
}

/// 长上下文：异步压缩任务
model AiContextCompactionJob {
  id               Int                          @id @default(autoincrement())
  conversationId   Int                          @map("conversation_id")
  fromSeq          Int                          @map("from_seq")
  toSeq            Int                          @map("to_seq")
  status           AiContextCompactionJobStatus @default(PENDING)
  idempotencyKey   String                       @unique @map("idempotency_key") @db.VarChar(255)
  attempts         Int                          @default(0)
  maxAttempts      Int                          @default(5) @map("max_attempts")
  lastError        String?                      @map("last_error") @db.Text
  scheduledAt      DateTime?                    @map("scheduled_at")
  lockedAt         DateTime?                    @map("locked_at")
  startedAt        DateTime?                    @map("started_at")
  finishedAt       DateTime?                    @map("finished_at")
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")

  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  producedChunks  AiContextChunk[]

  @@index([conversationId, status])
  @@index([status, scheduledAt])
  @@map("ai_context_compaction_job")
}

/// 长上下文：一次压缩产出的分块（可由 `producedByJob` 回联任务）
model AiContextChunk {
  id                Int      @id @default(autoincrement())
  conversationId    Int      @map("conversation_id")
  startSeq          Int      @map("start_seq")
  endSeq            Int      @map("end_seq")
  summary           String   @db.Text
  producedByJobId   Int?     @map("produced_by_job_id")
  sourceHash        String?  @map("source_hash")
  createdAt         DateTime @default(now()) @map("created_at")

  conversation   AiConversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  producedByJob  AiContextCompactionJob? @relation(fields: [producedByJobId], references: [id], onDelete: SetNull)

  @@index([conversationId, startSeq])
  @@index([producedByJobId])
  @@map("ai_context_chunk")
}

model AiMessage {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  seq            Int
  role           AiMessageRole
  text           String?      @db.Text
  contentJson    Json?        @map("content_json")
  providerMeta   Json?        @map("provider_meta")
  createdAt      DateTime     @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls    AiToolCall[]

  @@unique([conversationId, seq])
  @@index([conversationId, seq])
  @@map("ai_message")
}

model AiToolCall {
  id            Int       @id @default(autoincrement())
  messageId     Int       @map("message_id")
  idempotencyKey String?  @map("idempotency_key")
  name          String
  input         Json
  status        String
  output        Json?
  error         String?   @db.Text
  externalId    String?   @map("external_id")
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")

  message AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("ai_tool_call")
}

/// 单份简历维度的「全局」上下文（如 JD），该简历下所有 AiConversation 共享
model AiGlobalContext {
  id        Int      @id @default(autoincrement())
  resumeId  Int
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, key])
  @@index([resumeId])
  @@map("ai_global_context")
}

/// 可选：自管 LangGraph checkpoint；若改用 Redis/Postgres 官方存储可移除此表
model AiCheckpointer {
  id               Int      @id @default(autoincrement())
  threadId         String   @map("thread_id")
  checkpointId     String   @map("checkpoint_id")
  parentCheckpointId String? @map("parent_checkpoint_id")
  stateJson        Json?    @map("state_json")
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([threadId, checkpointId])
  @@map("ai_checkpointer")
}
